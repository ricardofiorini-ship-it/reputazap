{
  "trailingSlash": false,
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "reputazap.com" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.reputazap.com" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "reputazap.com.br" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.reputazap.com.br" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.startouch.com.br" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/", "destination": "/landing", "permanent": false },
    { "source": "/app-v2", "destination": "/app", "permanent": true },
    { "source": "/app-v2/(.*)", "destination": "/app/$1", "permanent": true },
    { "source": "/landing.html", "destination": "/landing", "permanent": true },
    { "source": "/ativar.html", "destination": "/ativar", "permanent": true },
    { "source": "/kit.html", "destination": "/kit", "permanent": true },
    { "source": "/ativar-placa.html", "destination": "/ativar-placa", "permanent": true },
    { "source": "/avaliar.html", "destination": "/avaliar", "permanent": true },
    { "source": "/reset.html", "destination": "/reset", "permanent": true },
    { "source": "/comece.html", "destination": "/comece", "permanent": true },
    { "source": "/diagnostico.html", "destination": "/app", "permanent": false },
    { "source": "/diagnostico", "destination": "/app", "permanent": false },
    { "source": "/plano-pro.html", "destination": "/plano-pro", "permanent": true },
    { "source": "/ajuda.html", "destination": "/ajuda", "permanent": true },
    { "source": "/sobre.html", "destination": "/sobre", "permanent": true },
    { "source": "/ranking.html", "destination": "/ranking", "permanent": true },
    { "source": "/radar.html", "destination": "/radar", "permanent": true },
    { "source": "/radar-land.html", "destination": "/radar-land", "permanent": true }
  ],
  "rewrites": [
    { "source": "/landing", "destination": "/landing.html" },
    { "source": "/ativar", "destination": "/ativar.html" },
    { "source": "/kit", "destination": "/kit.html" },
    { "source": "/ativar-placa", "destination": "/ativar-placa.html" },
    { "source": "/avaliar", "destination": "/avaliar.html" },
    { "source": "/reset", "destination": "/reset.html" },
    { "source": "/comece", "destination": "/comece.html" },
    { "source": "/admin/producao", "destination": "/admin-producao.html" },
    { "source": "/admin/estoque", "destination": "/admin-estoque.html" },
    { "source": "/admin/clientes", "destination": "/admin-clientes.html" },
    { "source": "/admin/prospects", "destination": "/admin-prospects.html" },
    { "source": "/ativar-codigo", "destination": "/ativar-codigo.html" },
    { "source": "/plano-pro", "destination": "/plano-pro.html" },
    { "source": "/ajuda", "destination": "/ajuda.html" },
    { "source": "/sobre", "destination": "/sobre.html" },
    { "source": "/ranking", "destination": "/ranking.html" },
    { "source": "/radar", "destination": "/radar.html" },
    { "source": "/radar-land", "destination": "/radar-land.html" },
    { "source": "/r/:code", "destination": "/api/r/:code" },
    { "source": "/artigos", "destination": "/artigos/index.html" },
    { "source": "/artigos/:slug", "destination": "/artigos/:slug.html" },
    { "source": "/app", "destination": "/index-v2.html" },
    { "source": "/app/(.*)", "destination": "/index-v2.html" },
    { "source": "/app-legacy", "destination": "/index.html" }
  ],
  "functions": {
    "api/radar.js": { "maxDuration": 90 }
  },
  "crons": [
    { "path": "/api/cron/snapshot-competitors", "schedule": "0 4 * * 1" },
    { "path": "/api/cron/review-alerts", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/db-health", "schedule": "0 * * * *" }
  ]
}
