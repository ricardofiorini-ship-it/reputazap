{
  "trailingSlash": false,
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "reputazap.com" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.reputazap.com" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "reputazap.com.br" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.reputazap.com.br" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.startouch.com.br" }], "destination": "https://startouch.com.br/$1", "permanent": true },
    { "source": "/", "destination": "/landing", "permanent": false },
    { "source": "/landing.html", "destination": "/landing", "permanent": true },
    { "source": "/ativar.html", "destination": "/ativar", "permanent": true },
    { "source": "/kit.html", "destination": "/kit", "permanent": true },
    { "source": "/ativar-placa.html", "destination": "/ativar-placa", "permanent": true },
    { "source": "/avaliar.html", "destination": "/avaliar", "permanent": true },
    { "source": "/reset.html", "destination": "/reset", "permanent": true },
    { "source": "/comece.html", "destination": "/comece", "permanent": true },
    { "source": "/diagnostico.html", "destination": "/diagnostico", "permanent": true }
  ],
  "rewrites": [
    { "source": "/landing", "destination": "/landing.html" },
    { "source": "/ativar", "destination": "/ativar.html" },
    { "source": "/kit", "destination": "/kit.html" },
    { "source": "/ativar-placa", "destination": "/ativar-placa.html" },
    { "source": "/avaliar", "destination": "/avaliar.html" },
    { "source": "/reset", "destination": "/reset.html" },
    { "source": "/comece", "destination": "/comece.html" },
    { "source": "/diagnostico", "destination": "/diagnostico.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" }
  ]
}
